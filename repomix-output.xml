@layer base {
  * {
    @apply border-border outline-ring/50;
  }

  body {
    @apply bg-background text-foreground;
  }

  button,
  a,
  [role="button"] {
    @apply cursor-pointer transition-all duration-200 ease-in-out;
  }

  input:focus,
  textarea:focus,
  select:focus,
  button:focus {
    @apply transition-all duration-200 ease-in-out;
  }

  /* Focus ring chuẩn Accessibility */
  :is(input, textarea, select, button, a, [role="button"], [tabindex]):focus-visible {
    outline: 2px solid rgb(var(--ring));
    outline-offset: 2px;
  }
}

@layer components {

  /* Ép kiểu cho description */
  [data-sonner-toast] [data-description] {
    color: rgb(var(--muted-foreground));
  }

  /* TOAST ERROR */
  .toast-error {
    background-color: rgb(var(--card)) !important;
    border: 1px solid rgb(var(--destructive) / 0.3) !important;
    /* Opacity 30% */
    border-left: 4px solid rgb(var(--destructive)) !important;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1) !important;
  }

  /* Chọn tất cả phần tử con bên trong toast error */
  .toast-error :is([data-title], [data-description], [data-icon], svg) {
    color: rgb(var(--destructive)) !important;
  }

  /* TOAST SUCCESS */
  .toast-success {
    background-color: rgb(var(--card)) !important;
    border: 1px solid rgb(var(--success) / 0.3) !important;
    border-left: 4px solid rgb(var(--success)) !important;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1) !important;
  }

  .toast-success :is([data-title], [data-description], [data-icon], svg) {
    color: rgb(var(--success)) !important;
  }
}
