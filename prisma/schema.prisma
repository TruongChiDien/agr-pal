generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH
// ============================================================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password_hash String
  role          String   @default("ADMIN")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("users")
}

// ============================================================
// MASTERS
// ============================================================

/// Loại máy (vd: "Máy cắt lúa", "Máy cày")
/// Mỗi loại máy sở hữu các loại công việc (job_types) riêng
model MachineType {
  id          String      @id @default(cuid())
  name        String
  description String?
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  job_types   Job_Type[]
  machines    Machine[]
  service_machine_types ServiceMachineType[]

  @@map("machine_types")
}

/// Loại công việc/vị trí — thuộc về 1 MachineType cụ thể
/// Vd: "Máy cắt lúa" có "Tài xế" (500k) + "Cột bao" (300k)
model Job_Type {
  id                  String             @id @default(cuid())
  machine_type_id     String
  name                String
  default_base_salary Decimal            @db.Decimal(12, 2)
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt
  machine_type        MachineType        @relation(fields: [machine_type_id], references: [id], onDelete: Cascade)
  daily_workers       DailyMachineWorker[]

  @@index([machine_type_id])
  @@map("job_types")
}

/// Dịch vụ nông nghiệp (vd: "Cắt lúa", "Cày đất")
model Service {
  id           String               @id @default(cuid())
  name         String
  unit         String               @default("công")
  price        Decimal              @db.Decimal(12, 2)
  description  String?
  created_at   DateTime             @default(now())
  updated_at   DateTime             @updatedAt
  machine_types ServiceMachineType[]

  @@map("services")
}

/// Many-to-many: service ↔ machine_type
model ServiceMachineType {
  service_id      String
  machine_type_id String
  service         Service     @relation(fields: [service_id], references: [id], onDelete: Cascade)
  machine_type    MachineType @relation(fields: [machine_type_id], references: [id], onDelete: Cascade)

  @@id([service_id, machine_type_id])
  @@map("service_machine_types")
}

model Worker {
  id               String               @id @default(cuid())
  name             String
  phone            String?
  address          String?
  created_at       DateTime             @default(now())
  updated_at       DateTime             @updatedAt
  advance_payments Advance_Payment[]
  payroll_sheets   Payroll_Sheet[]
  daily_workers    DailyMachineWorker[]

  @@map("workers")
}

/// Máy nông nghiệp — thuộc 1 MachineType cụ thể
model Machine {
  id               String         @id @default(cuid())
  name             String
  model            String?
  machine_type_id  String
  purchase_date    DateTime?
  status           MachineStatus  @default(AVAILABLE)
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  machine_type     MachineType    @relation(fields: [machine_type_id], references: [id])
  maintenance_logs MaintenanceLog[]
  daily_machines   DailyMachine[]

  @@index([machine_type_id])
  @@map("machines")
}

// ============================================================
// CUSTOMERS
// ============================================================

model Customer {
  id         String    @id @default(cuid())
  name       String
  phone      String?
  address    String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  bills      Bill[]
  bookings   Booking[]
  lands      Land[]

  @@map("customers")
}

model Land {
  id          String    @id @default(cuid())
  customer_id String
  name        String
  gps_lat     Decimal?  @db.Decimal(10, 7)
  gps_lng     Decimal?  @db.Decimal(10, 7)
  created_at  DateTime  @default(now())
  bookings    Booking[]
  customer    Customer  @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([customer_id])
  @@map("lands")
}

// ============================================================
// OPERATIONS — DATE-CENTRIC
// ============================================================

/// Ngày làm việc — đơn vị trung tâm của hệ thống
model WorkDay {
  id             String         @id @default(cuid())
  date           DateTime       @unique @db.Date
  notes          String?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  daily_bookings DailyBooking[]
  daily_machines DailyMachine[]

  @@index([date])
  @@map("work_days")
}

/// Booking của khách hàng
model Booking {
  id             String         @id @default(cuid())
  customer_id    String
  land_id        String?
  amount         Decimal?       @db.Decimal(12, 2)
  status         BookingStatus  @default(NEW)
  payment_status PaymentStatus  @default(PENDING_BILL)
  bill_id        String?
  notes          String?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  bill           Bill?          @relation(fields: [bill_id], references: [id])
  customer       Customer       @relation(fields: [customer_id], references: [id])
  land           Land?          @relation(fields: [land_id], references: [id])
  daily_bookings DailyBooking[]

  @@index([customer_id])
  @@index([status])
  @@index([payment_status])
  @@index([bill_id])
  @@map("bookings")
}

/// Booking tham gia trong 1 ngày cụ thể
model DailyBooking {
  id          String                @id @default(cuid())
  work_day_id String
  booking_id  String
  amount      Decimal?              @db.Decimal(12, 2)
  notes       String?
  created_at  DateTime              @default(now())
  updated_at  DateTime              @updatedAt
  work_day    WorkDay               @relation(fields: [work_day_id], references: [id], onDelete: Cascade)
  booking     Booking               @relation(fields: [booking_id], references: [id])
  machines    DailyBookingMachine[]

  @@unique([work_day_id, booking_id])
  @@index([work_day_id])
  @@index([booking_id])
  @@map("daily_bookings")
}

/// Machine hoạt động trong 1 ngày
model DailyMachine {
  id          String                @id @default(cuid())
  work_day_id String
  machine_id  String
  amount      Decimal?              @db.Decimal(12, 2)
  notes       String?
  created_at  DateTime              @default(now())
  updated_at  DateTime              @updatedAt
  work_day    WorkDay               @relation(fields: [work_day_id], references: [id], onDelete: Cascade)
  machine     Machine               @relation(fields: [machine_id], references: [id])
  workers     DailyMachineWorker[]
  bookings    DailyBookingMachine[]

  @@unique([work_day_id, machine_id])
  @@index([work_day_id])
  @@index([machine_id])
  @@map("daily_machines")
}

/// Worker làm việc trên 1 machine trong 1 ngày
/// job_type_id snapshot: loại công việc tại thời điểm assign
model DailyMachineWorker {
  id                 String           @id @default(cuid())
  daily_machine_id   String
  worker_id          String
  job_type_id        String
  applied_base       Decimal          @db.Decimal(12, 2)
  applied_weight     Decimal          @db.Decimal(5, 2)
  payment_adjustment Decimal          @default(0) @db.Decimal(12, 2)
  payroll_id         String?
  payment_status     JobPaymentStatus @default(PENDING_PAYROLL)
  notes              String?
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt
  daily_machine      DailyMachine     @relation(fields: [daily_machine_id], references: [id], onDelete: Cascade)
  worker             Worker           @relation(fields: [worker_id], references: [id])
  job_type           Job_Type         @relation(fields: [job_type_id], references: [id])
  payroll            Payroll_Sheet?   @relation(fields: [payroll_id], references: [id])

  @@unique([daily_machine_id, worker_id])
  @@index([daily_machine_id])
  @@index([worker_id])
  @@index([job_type_id])
  @@index([payroll_id])
  @@map("daily_machine_workers")
}

/// Liên kết trace-back: booking nào đã dùng machine nào trong ngày
model DailyBookingMachine {
  id               String       @id @default(cuid())
  daily_booking_id String
  daily_machine_id String
  created_at       DateTime     @default(now())
  daily_booking    DailyBooking @relation(fields: [daily_booking_id], references: [id], onDelete: Cascade)
  daily_machine    DailyMachine @relation(fields: [daily_machine_id], references: [id], onDelete: Cascade)

  @@unique([daily_booking_id, daily_machine_id])
  @@map("daily_booking_machines")
}

// ============================================================
// FINANCIALS
// ============================================================

model Bill {
  id           String        @id @default(cuid())
  customer_id  String
  total_amount Decimal       @db.Decimal(12, 2)
  total_paid   Decimal       @default(0) @db.Decimal(12, 2)
  status       BillStatus    @default(OPEN)
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  adjustment   Decimal       @default(0) @db.Decimal(12, 2)
  notes        String?
  subtotal     Decimal       @default(0) @db.Decimal(12, 2)
  payments     BillPayment[]
  customer     Customer      @relation(fields: [customer_id], references: [id])
  bookings     Booking[]

  @@index([customer_id])
  @@index([status])
  @@map("bills")
}

model BillPayment {
  id           String        @id @default(cuid())
  bill_id      String
  amount       Decimal       @db.Decimal(12, 2)
  payment_date DateTime
  method       PaymentMethod
  notes        String?
  created_at   DateTime      @default(now())
  bill         Bill          @relation(fields: [bill_id], references: [id], onDelete: Cascade)

  @@index([bill_id])
  @@index([payment_date])
  @@map("bill_payments")
}

model Advance_Payment {
  id         String         @id @default(cuid())
  worker_id  String
  amount     Decimal        @db.Decimal(12, 2)
  status     AdvanceStatus  @default(UNPROCESSED)
  payroll_id String?
  notes      String?
  created_at DateTime       @default(now())
  payroll    Payroll_Sheet? @relation(fields: [payroll_id], references: [id])
  worker     Worker         @relation(fields: [worker_id], references: [id])

  @@index([worker_id])
  @@index([status])
  @@index([payroll_id])
  @@map("advance_payments")
}

model Payroll_Sheet {
  id               String               @id @default(cuid())
  worker_id        String
  total_wages      Decimal              @db.Decimal(12, 2)
  total_adv        Decimal              @default(0) @db.Decimal(12, 2)
  adjustment       Decimal              @default(0) @db.Decimal(12, 2)
  net_payable      Decimal              @db.Decimal(12, 2)
  total_paid       Decimal              @default(0) @db.Decimal(12, 2)
  status           PayrollStatus        @default(OPEN)
  notes            String?
  created_at       DateTime             @default(now())
  updated_at       DateTime             @updatedAt
  advance_payments Advance_Payment[]
  daily_workers    DailyMachineWorker[]
  payments         Payroll_Payment[]
  worker           Worker               @relation(fields: [worker_id], references: [id])

  @@index([worker_id])
  @@index([status])
  @@map("payroll_sheets")
}

model Payroll_Payment {
  id           String        @id @default(cuid())
  payroll_id   String
  amount       Decimal       @db.Decimal(12, 2)
  payment_date DateTime
  method       PaymentMethod
  notes        String?
  created_at   DateTime      @default(now())
  payroll      Payroll_Sheet @relation(fields: [payroll_id], references: [id], onDelete: Cascade)

  @@index([payroll_id])
  @@index([payment_date])
  @@map("payroll_payments")
}

// ============================================================
// MAINTENANCE
// ============================================================

model MaintenanceCategory {
  id         String           @id @default(cuid())
  name       String           @unique
  created_at DateTime         @default(now())
  logs       MaintenanceLog[]

  @@map("maintenance_categories")
}

model MaintenanceLog {
  id               String              @id @default(cuid())
  machine_id       String
  category_id      String
  brand            String?
  price            Decimal             @db.Decimal(12, 2)
  quantity         Int                 @default(1)
  maintenance_date DateTime
  notes            String?
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt
  category         MaintenanceCategory @relation(fields: [category_id], references: [id])
  machine          Machine             @relation(fields: [machine_id], references: [id], onDelete: Cascade)

  @@index([machine_id])
  @@index([category_id])
  @@index([maintenance_date])
  @@map("maintenance_logs")
}

// ============================================================
// ENUMS
// ============================================================

enum MachineStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
}

enum BookingStatus {
  NEW
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  PENDING_BILL
  ADDED_BILL
  FULLY_PAID
}

enum JobPaymentStatus {
  PENDING_PAYROLL
  ADDED_PAYROLL
  FULLY_PAID
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
}

enum BillStatus {
  OPEN
  PARTIAL_PAID
  COMPLETED
}

enum AdvanceStatus {
  UNPROCESSED
  PROCESSED
}

enum PayrollStatus {
  OPEN
  PARTIAL_PAID
  COMPLETED
}
