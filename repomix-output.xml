@import "tailwindcss";
@import "tw-animate-css";

@custom-variant dark (&:is(.dark *));

@theme inline {
  /* Color mappings */
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-success: var(--success);
  --color-warning: var(--warning);
  --color-destructive: var(--destructive);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-border: var(--border);
  --color-input: var(--input);
  --color-ring: var(--ring);

  /* Chart colors */
  --color-chart-1: var(--chart-1);
  --color-chart-2: var(--chart-2);
  --color-chart-3: var(--chart-3);
  --color-chart-4: var(--chart-4);
  --color-chart-5: var(--chart-5);

  /* Sidebar colors */
  --color-sidebar: var(--sidebar);
  --color-sidebar-foreground: var(--sidebar-foreground);
  --color-sidebar-primary: var(--sidebar-primary);
  --color-sidebar-primary-foreground: var(--sidebar-primary-foreground);
  --color-sidebar-accent: var(--sidebar-accent);
  --color-sidebar-accent-foreground: var(--sidebar-accent-foreground);
  --color-sidebar-border: var(--sidebar-border);
  --color-sidebar-ring: var(--sidebar-ring);

  /* Border radius tokens */
  --radius-sm: calc(var(--radius) - 4px);
  --radius-md: calc(var(--radius) - 2px);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) + 4px);
  --radius-2xl: calc(var(--radius) + 8px);
  --radius-3xl: calc(var(--radius) + 12px);
  --radius-4xl: calc(var(--radius) + 16px);

  /* Font - Inter for professional agricultural ERP */
  --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
  --font-mono: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
}

:root {
  /* Agricultural ERP Brand Colors */
  --radius: 0.75rem; /* 12px - rounded-xl */

  /* Core Colors */
  --background: 248 250 252; /* Slate 50 - Light gray background */
  --foreground: 15 23 42; /* Slate 900 - Dark text */

  /* Primary - Agricultural Green */
  --primary: 21 128 61; /* Green 700 - Agricultural theme */
  --primary-foreground: 255 255 255; /* White text on primary */

  /* Secondary - Professional Slate */
  --secondary: 30 41 59; /* Slate 800 - Professional */
  --secondary-foreground: 248 250 252; /* Light text on secondary */

  /* Accent - Machinery Yellow */
  --accent: 234 179 8; /* Yellow 500 - Machinery accent */
  --accent-foreground: 30 41 59; /* Dark text on accent */

  /* Status Colors */
  --success: 34 197 94; /* Green 500 - Completed status */
  --warning: 245 158 11; /* Orange 500 - In-progress/pending */
  --destructive: 239 68 68; /* Red 500 - Debt/Canceled */

  /* Muted */
  --muted: 241 245 249; /* Slate 100 */
  --muted-foreground: 100 116 139; /* Slate 500 */

  /* Card */
  --card: 255 255 255; /* White */
  --card-foreground: 15 23 42; /* Slate 900 */

  /* Popover */
  --popover: 255 255 255; /* White */
  --popover-foreground: 15 23 42; /* Slate 900 */

  /* Border & Input */
  --border: 226 232 240; /* Slate 200 */
  --input: 226 232 240; /* Slate 200 */
  --ring: 21 128 61; /* Green 700 - Focus ring matches primary */

  /* Chart Colors - Agricultural themed */
  --chart-1: 34 197 94; /* Green 500 - Revenue/Growth */
  --chart-2: 234 179 8; /* Yellow 500 - Machinery */
  --chart-3: 59 130 246; /* Blue 500 - Water/Irrigation */
  --chart-4: 168 85 247; /* Purple 500 - Services */
  --chart-5: 236 72 153; /* Pink 500 - Additional metric */

  /* Sidebar */
  --sidebar: 255 255 255; /* White sidebar */
  --sidebar-foreground: 15 23 42; /* Dark text */
  --sidebar-primary: 21 128 61; /* Green active items */
  --sidebar-primary-foreground: 255 255 255; /* White text on active */
  --sidebar-accent: 240 253 244; /* Green 50 - Hover state */
  --sidebar-accent-foreground: 21 128 61; /* Green text on hover */
  --sidebar-border: 226 232 240; /* Slate 200 */
  --sidebar-ring: 21 128 61; /* Green focus ring */
}

.dark {
  /* Dark Mode - Agricultural ERP Theme */
  --background: 15 23 42; /* Slate 900 - Dark background */
  --foreground: 248 250 252; /* Slate 50 - Light text */

  /* Primary - Lighter green for dark mode */
  --primary: 34 197 94; /* Green 500 - Brighter for dark bg */
  --primary-foreground: 15 23 42; /* Dark text on primary */

  /* Secondary */
  --secondary: 51 65 85; /* Slate 700 */
  --secondary-foreground: 248 250 252; /* Light text */

  /* Accent - Brighter yellow for dark mode */
  --accent: 250 204 21; /* Yellow 400 - Brighter for dark bg */
  --accent-foreground: 15 23 42; /* Dark text on accent */

  /* Status Colors - Adjusted for dark mode */
  --success: 34 197 94; /* Green 500 */
  --warning: 251 146 60; /* Orange 400 */
  --destructive: 248 113 113; /* Red 400 */

  /* Muted */
  --muted: 51 65 85; /* Slate 700 */
  --muted-foreground: 148 163 184; /* Slate 400 */

  /* Card */
  --card: 30 41 59; /* Slate 800 */
  --card-foreground: 248 250 252; /* Light text */

  /* Popover */
  --popover: 30 41 59; /* Slate 800 */
  --popover-foreground: 248 250 252; /* Light text */

  /* Border & Input */
  --border: 51 65 85; /* Slate 700 */
  --input: 51 65 85; /* Slate 700 */
  --ring: 34 197 94; /* Green 500 - Focus ring */

  /* Chart Colors - Brighter for dark mode */
  --chart-1: 34 197 94; /* Green 500 */
  --chart-2: 250 204 21; /* Yellow 400 */
  --chart-3: 96 165 250; /* Blue 400 */
  --chart-4: 192 132 252; /* Purple 400 */
  --chart-5: 244 114 182; /* Pink 400 */

  /* Sidebar */
  --sidebar: 30 41 59; /* Slate 800 */
  --sidebar-foreground: 248 250 252; /* Light text */
  --sidebar-primary: 34 197 94; /* Green 500 */
  --sidebar-primary-foreground: 15 23 42; /* Dark text on active */
  --sidebar-accent: 51 65 85; /* Slate 700 - Hover state */
  --sidebar-accent-foreground: 34 197 94; /* Green text on hover */
  --sidebar-border: 51 65 85; /* Slate 700 */
  --sidebar-ring: 34 197 94; /* Green focus ring */
}

@layer base {
  * {
    @apply border-border outline-ring/50;
  }
  body {
    @apply bg-background text-foreground;
  }
}

/* Desktop-optimized interactions */
button,
a,
[role="button"] {
  cursor: pointer;
  transition: all 0.2s ease;
}

/* Smooth focus transitions */
input:focus,
textarea:focus,
select:focus,
button:focus {
  transition: all 0.2s ease;
}

/* Touch targets for responsive views */
@media (max-width: 768px) {
  button,
  a,
  [role="button"],
  input[type="checkbox"],
  input[type="radio"] {
    min-height: 44px; /* iOS recommended touch target */
    min-width: 44px;
  }
}

/* Agricultural ERP Custom Utilities */
.text-success {
  color: rgb(var(--success));
}

.text-warning {
  color: rgb(var(--warning));
}

.bg-success {
  background-color: rgb(var(--success));
}

.bg-warning {
  background-color: rgb(var(--warning));
}

.border-success {
  border-color: rgb(var(--success));
}

.border-warning {
  border-color: rgb(var(--warning));
}
