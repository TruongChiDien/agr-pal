<file path="prisma/schema.prisma">
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password_hash String
  role          String   @default("ADMIN")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("users")
}

model Service {
  id          String     @id @default(cuid())
  name        String
  unit        String
  description String?
  price       Decimal    @db.Decimal(12, 2)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  bookings    Booking[]
  job_types   Job_Type[]

  @@map("services")
}

model Job_Type {
  id                  String          @id @default(cuid())
  service_id          String
  name                String
  default_base_salary Decimal         @db.Decimal(12, 2)
  created_at          DateTime        @default(now())
  service             Service         @relation(fields: [service_id], references: [id], onDelete: Cascade)
  jobs                Job[]
  worker_weights      Worker_Weight[]

  @@index([service_id])
  @@map("job_types")
}

model Worker {
  id               String            @id @default(cuid())
  name             String
  phone            String?
  address          String?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  advance_payments Advance_Payment[]
  jobs             Job[]
  payroll_sheets   Payroll_Sheet[]
  worker_weights   Worker_Weight[]

  @@map("workers")
}

model Worker_Weight {
  id          String   @id @default(cuid())
  worker_id   String
  job_type_id String
  weight      Decimal  @db.Decimal(5, 2)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  job_type    Job_Type @relation(fields: [job_type_id], references: [id], onDelete: Cascade)
  worker      Worker   @relation(fields: [worker_id], references: [id], onDelete: Cascade)

  @@unique([worker_id, job_type_id])
  @@index([worker_id])
  @@index([job_type_id])
  @@map("worker_weights")
}

model Machine {
  id            String        @id @default(cuid())
  name          String
  model         String?
  type          String?
  purchase_date DateTime?
  status        MachineStatus @default(AVAILABLE)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  jobs             Job[]
  maintenance_logs MaintenanceLog[]

  @@map("machines")
}

model Customer {
  id         String    @id @default(cuid())
  name       String
  phone      String?
  address    String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  bills      Bill[]
  bookings   Booking[]
  lands      Land[]

  @@map("customers")
}

model Land {
  id          String    @id @default(cuid())
  customer_id String
  name        String
  gps_lat     Decimal?  @db.Decimal(10, 7)
  gps_lng     Decimal?  @db.Decimal(10, 7)
  created_at  DateTime  @default(now())
  bookings    Booking[]
  customer    Customer  @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([customer_id])
  @@map("lands")
}

model Booking {
  id             String        @id @default(cuid())
  customer_id    String
  land_id        String?
  service_id     String
  quantity       Decimal?      @db.Decimal(10, 2)
  captured_price Decimal       @db.Decimal(12, 2)
  adjustment     Decimal       @default(0) @db.Decimal(12, 2)
  total_amount   Decimal       @db.Decimal(12, 2)
  status         BookingStatus @default(NEW)
  payment_status PaymentStatus @default(PENDING_BILL)
  bill_id        String?
  notes          String?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  bill           Bill?         @relation(fields: [bill_id], references: [id])
  customer       Customer      @relation(fields: [customer_id], references: [id])
  land           Land?         @relation(fields: [land_id], references: [id])
  service        Service       @relation(fields: [service_id], references: [id])
  jobs           Job[]

  @@index([customer_id])
  @@index([status])
  @@index([payment_status])
  @@index([bill_id])
  @@map("bookings")
}

model Job {
  id             String           @id @default(cuid())
  booking_id     String
  job_type_id    String
  machine_id     String?
  status         JobStatus        @default(NEW)
  notes          String?
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  worker_id      String
  actual_qty     Decimal          @default(0) @db.Decimal(10, 2)
  applied_base   Decimal          @db.Decimal(12, 2)
  applied_weight Decimal          @db.Decimal(5, 2)
  payment_adjustment Decimal      @default(0) @db.Decimal(12, 2)
  final_pay      Decimal          @db.Decimal(12, 2)
  payroll_id     String?
  payment_status JobPaymentStatus @default(PENDING_PAYROLL)
  booking        Booking          @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  job_type       Job_Type         @relation(fields: [job_type_id], references: [id])
  machine        Machine?         @relation(fields: [machine_id], references: [id])
  payroll        Payroll_Sheet?   @relation(fields: [payroll_id], references: [id])
  worker         Worker           @relation(fields: [worker_id], references: [id])

  @@index([booking_id])
  @@index([worker_id])
  @@index([status])
  @@index([payment_status])
  @@index([payroll_id])
  @@map("jobs")
}

model Bill {
  id              String        @id @default(cuid())
  customer_id     String
  total_amount    Decimal       @db.Decimal(12, 2)
  total_paid      Decimal       @default(0) @db.Decimal(12, 2)
  status          BillStatus    @default(OPEN)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  adjustment      Decimal       @default(0) @db.Decimal(12, 2)
  notes           String?
  subtotal        Decimal       @default(0) @db.Decimal(12, 2)
  payments        BillPayment[]
  customer        Customer      @relation(fields: [customer_id], references: [id])
  bookings        Booking[]

  @@index([customer_id])
  @@index([status])
  @@map("bills")
}

model BillPayment {
  id           String        @id @default(cuid())
  bill_id      String
  amount       Decimal       @db.Decimal(12, 2)
  payment_date DateTime
  method       PaymentMethod
  notes        String?
  created_at   DateTime      @default(now())
  bill         Bill          @relation(fields: [bill_id], references: [id], onDelete: Cascade)

  @@index([bill_id])
  @@index([payment_date])
  @@map("bill_payments")
}

model Advance_Payment {
  id         String         @id @default(cuid())
  worker_id  String
  amount     Decimal        @db.Decimal(12, 2)
  status     AdvanceStatus  @default(UNPROCESSED)
  payroll_id String?
  notes      String?
  created_at DateTime       @default(now())
  payroll    Payroll_Sheet? @relation(fields: [payroll_id], references: [id])
  worker     Worker         @relation(fields: [worker_id], references: [id])

  @@index([worker_id])
  @@index([status])
  @@index([payroll_id])
  @@map("advance_payments")
}

model Payroll_Sheet {
  id               String            @id @default(cuid())
  worker_id        String
  total_wages      Decimal           @db.Decimal(12, 2)
  total_adv        Decimal           @default(0) @db.Decimal(12, 2)
  adjustment       Decimal           @default(0) @db.Decimal(12, 2)
  net_payable      Decimal           @db.Decimal(12, 2)
  total_paid       Decimal           @default(0) @db.Decimal(12, 2)
  status           PayrollStatus     @default(OPEN)
  notes            String?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  advance_payments Advance_Payment[]
  jobs             Job[]
  payments         Payroll_Payment[]
  worker           Worker            @relation(fields: [worker_id], references: [id])

  @@index([worker_id])
  @@index([status])
  @@map("payroll_sheets")
}

model Payroll_Payment {
  id           String        @id @default(cuid())
  payroll_id   String
  amount       Decimal       @db.Decimal(12, 2)
  payment_date DateTime
  method       PaymentMethod
  notes        String?
  created_at   DateTime      @default(now())
  payroll      Payroll_Sheet @relation(fields: [payroll_id], references: [id], onDelete: Cascade)

  @@index([payroll_id])
  @@index([payment_date])
  @@map("payroll_payments")
}

model MaintenanceCategory {
  id         String           @id @default(cuid())
  name       String           @unique
  created_at DateTime         @default(now())
  logs       MaintenanceLog[]

  @@map("maintenance_categories")
}

model MaintenanceLog {
  id               String              @id @default(cuid())
  machine_id       String
  category_id      String
  brand            String?
  price            Decimal             @db.Decimal(12, 2)
  quantity         Int                 @default(1)
  maintenance_date DateTime
  notes            String?
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt
  category         MaintenanceCategory @relation(fields: [category_id], references: [id])
  machine          Machine             @relation(fields: [machine_id], references: [id], onDelete: Cascade)

  @@index([machine_id])
  @@index([category_id])
  @@index([maintenance_date])
  @@map("maintenance_logs")
}

enum MachineStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
}

enum BookingStatus {
  NEW
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  PENDING_BILL
  ADDED_BILL
  FULLY_PAID
}

enum JobStatus {
  NEW
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELED
}

enum JobPaymentStatus {
  PENDING_PAYROLL
  ADDED_PAYROLL
  FULLY_PAID
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
}

enum BillStatus {
  OPEN
  PARTIAL_PAID
  COMPLETED
}

enum AdvanceStatus {
  UNPROCESSED
  PROCESSED
}

enum PayrollStatus {
  OPEN
  PARTIAL_PAID
  COMPLETED
}
