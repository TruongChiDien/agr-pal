  job_types: z
    .array(
      z.object({
        name: z.string().min(1, 'Tên loại công việc không được để trống').max(200),
        default_base_salary: z
          .number({ message: 'Lương cơ bản là bắt buộc' })
          .min(0, 'Lương cơ bản phải >= 0'),
      })
    )
    .optional(),
})

