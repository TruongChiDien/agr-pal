        variant="ghost"
        size="sm"
        className="h-6 w-6 p-0"
        onClick={handleSave}
        disabled={loading}
      >
        <Check className="h-3 w-3 text-green-600" />
      </Button>
      <Button
        variant="ghost"
        size="sm"
        className="h-6 w-6 p-0"
        onClick={() => setEditing(false)}
      >
        <X className="h-3 w-3 text-red-500" />
      </Button>
    </div>
  )
}
